# --- LLM Provider ---
# Get your FREE API key at: https://console.groq.com
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here

# --- Model Settings ---
# Free Groq models: llama-3.3-70b-versatile | llama3-8b-8192 | mixtral-8x7b-32768 | gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_TOKENS=1024
TEMPERATURE=0.1

# --- Retrieval Settings ---
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.4
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Paths ---
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
EMBEDDINGS_DIR=data/embeddings
FAISS_INDEX_PATH=data/embeddings/faiss_index

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
LOG_LEVEL=INFO

# --- Streamlit Settings ---
STREAMLIT_PORT=8501
